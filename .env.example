# ==================================================
# WhatsApp Cloud API - Configuração
# ==================================================

# Token de acesso permanente (gerar no Meta Business)
WHATSAPP_TOKEN=your_permanent_access_token_here

# ID do número de telefone registrado na API
PHONE_NUMBER_ID=your_phone_number_id_here

# ID da conta WhatsApp Business
WABA_ID=your_waba_id_here

# Token de verificação do webhook (defina qualquer string segura)
VERIFY_TOKEN=your_custom_verify_token_here

# App Secret (para validar assinatura dos webhooks)
APP_SECRET=your_app_secret_here

# ==================================================
# Servidor
# ==================================================
PORT=3000
NODE_ENV=development

# ==================================================
# Redis (para filas BullMQ)
# ==================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ==================================================
# Aquecimento
# ==================================================
# Fase atual: 1, 2, 3 ou 4
WARMUP_PHASE=1
# Máximo de mensagens por dia (ajustado por fase)
WARMUP_DAILY_LIMIT=50
# Intervalo mínimo entre mensagens (ms)
WARMUP_MIN_INTERVAL=5000
